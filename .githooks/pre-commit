#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Allow skipping for known false positives (use with extreme caution!)
if [ "${SKIP_SECRET_SCAN:-0}" = "1" ]; then
    echo -e "${YELLOW}⚠ SECRET SCAN SKIPPED by SKIP_SECRET_SCAN=1${NC}"
    echo -e "${YELLOW}  Make absolutely sure no secrets are being committed!${NC}"
    exit 0
fi

echo "🔒 Running pre-commit security checks..."

# ============================================================
# 1. Check for forbidden files that should never be committed
# ============================================================
FORBIDDEN_FILES=(
    "config.toml"
    ".env"
    ".env.local"
    ".env.production"
    "credentials.json"
    "service-account.json"
    "*.pem"
    "*.key"
    "*.p12"
    "*.pfx"
    "*.jks"
    "id_rsa"
    "id_ed25519"
    "id_ecdsa"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✓ No staged files to check${NC}"
    exit 0
fi

FOUND_FORBIDDEN=0
for pattern in "${FORBIDDEN_FILES[@]}"; do
    # Use grep with glob-style matching
    MATCHES=$(echo "$STAGED_FILES" | grep -E "(^|/)${pattern//\*/.*}$" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}✗ BLOCKED: Forbidden file staged for commit:${NC}"
        echo "$MATCHES" | while read -r f; do echo "  → $f"; done
        FOUND_FORBIDDEN=1
    fi
done

if [ "$FOUND_FORBIDDEN" -eq 1 ]; then
    echo -e "${RED}Remove these files from staging: git reset HEAD <file>${NC}"
    exit 1
fi

# ============================================================
# 2. Scan staged content for secret patterns
# ============================================================
SECRETS_FOUND=0

# Patterns that indicate secrets (applied to staged diff content)
SECRET_PATTERNS=(
    # API keys and tokens
    'sk-ant-api[0-9a-zA-Z_-]{20,}'          # Anthropic/Claude API key
    'sk-[a-zA-Z0-9]{20,}'                    # OpenAI-style API key
    'ghp_[a-zA-Z0-9]{36}'                    # GitHub personal access token
    'gho_[a-zA-Z0-9]{36}'                    # GitHub OAuth token
    'ghs_[a-zA-Z0-9]{36}'                    # GitHub server token
    'github_pat_[a-zA-Z0-9_]{22,}'           # GitHub fine-grained PAT
    'glpat-[a-zA-Z0-9_-]{20,}'              # GitLab PAT
    'xoxb-[0-9]{10,}-[a-zA-Z0-9]{20,}'      # Slack bot token
    'xoxp-[0-9]{10,}-[a-zA-Z0-9]{20,}'      # Slack user token
    'xoxs-[0-9]{10,}-[a-zA-Z0-9]{20,}'      # Slack session token

    # AWS
    'AKIA[0-9A-Z]{16}'                       # AWS access key ID
    'aws_secret_access_key\s*=\s*[A-Za-z0-9/+=]{40}'

    # Telegram bot token
    '[0-9]{8,10}:[a-zA-Z0-9_-]{35}'          # Telegram bot token

    # Private keys
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
    '-----BEGIN PGP PRIVATE KEY BLOCK-----'

    # Generic high-confidence patterns
    'password\s*[:=]\s*["\x27][^\s"'\'']{8,}'   # password = "..."
    'secret\s*[:=]\s*["\x27][^\s"'\'']{8,}'     # secret = "..."
    'api_key\s*[:=]\s*["\x27][^\s"'\'']{8,}'    # api_key = "..."
    'apikey\s*[:=]\s*["\x27][^\s"'\'']{8,}'     # apikey = "..."
    'token\s*[:=]\s*["\x27][^\s"'\'']{8,}'      # token = "..."
)

# Get staged diff content (only added/modified lines)
DIFF_CONTENT=$(git diff --cached --diff-filter=ACM -U0 2>/dev/null || true)

for pattern in "${SECRET_PATTERNS[@]}"; do
    MATCHES=$(echo "$DIFF_CONTENT" | grep -iEn "^\+" | grep -v "gitleaks:allow" | grep -iE "$pattern" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}✗ BLOCKED: Potential secret detected!${NC}"
        echo -e "  Pattern: ${YELLOW}${pattern}${NC}"
        # Show redacted match (first 10 chars + ***)
        echo "$MATCHES" | head -3 | while read -r line; do
            REDACTED=$(echo "$line" | sed -E 's/([a-zA-Z0-9_-]{10})[a-zA-Z0-9_-]{10,}/\1***/g')
            echo -e "  ${RED}${REDACTED}${NC}"
        done
        SECRETS_FOUND=1
    fi
done

if [ "$SECRETS_FOUND" -eq 1 ]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════${NC}"
    echo -e "${RED}  SECRET DETECTED! Commit blocked.${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════${NC}"
    echo ""
    echo "If this is a false positive, you can:"
    echo "  1. Add '# gitleaks:allow' comment on the line"
    echo "  2. Skip this check: SKIP_SECRET_SCAN=1 git commit ..."
    echo "     (use with extreme caution!)"
    exit 1
fi

# ============================================================
# 3. Run gitleaks if available (comprehensive scan)
# ============================================================
if command -v gitleaks &>/dev/null; then
    echo "Running gitleaks scan..."
    if ! gitleaks git --pre-commit --staged --redact --verbose 2>&1; then
        echo -e "${RED}✗ gitleaks found potential secrets!${NC}"
        echo ""
        echo "If this is a false positive, add the fingerprint to .gitleaksignore"
        exit 1
    fi
    echo -e "${GREEN}✓ gitleaks scan passed${NC}"
else
    echo -e "${YELLOW}⚠ gitleaks not installed. Using built-in patterns only.${NC}"
    echo "  Install: brew install gitleaks"
fi

# ============================================================
# 4. Check for large files (>1MB)
# ============================================================
LARGE_FILES=0
while IFS= read -r file; do
    if [ -f "$file" ]; then
        SIZE=$(wc -c < "$file" 2>/dev/null || echo 0)
        if [ "$SIZE" -gt 1048576 ]; then
            SIZE_MB=$(echo "scale=1; $SIZE/1048576" | bc 2>/dev/null || echo "?")
            echo -e "${YELLOW}⚠ Large file (${SIZE_MB}MB): $file${NC}"
            LARGE_FILES=1
        fi
    fi
done <<< "$STAGED_FILES"

if [ "$LARGE_FILES" -eq 1 ]; then
    echo -e "${YELLOW}Consider adding large files to .gitignore${NC}"
fi

echo -e "${GREEN}✓ All security checks passed${NC}"
